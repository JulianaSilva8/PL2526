PUSHI 0
PUSHI 0
PUSHI 0
PUSHS "Introduza um numero inteiro positivo:"
WRITES
WRITELN
READ
ATOI
STOREG 0
PUSHI 1
STOREG 2
PUSHI 2
STOREG 1
PRIMO20:
PUSHG 1
PUSHG 0
PUSHI 2
DIV
INFEQ
PUSHG 2
MUL
JZ IF1END
PUSHG 0
PUSHG 1
MOD
PUSHI 0
EQUAL
JZ IF2END
PUSHI 0
STOREG 2
IF2END:
PUSHG 1
PUSHI 1
ADD
STOREG 1
JUMP PRIMO20
IF1END:
PUSHG 2
JZ IF3ELSE
PUSHG 0
WRITEI
PUSHS " e um numero primo"
WRITES
WRITELN
JUMP IF3END
IF3ELSE:
PUSHG 0
WRITEI
PUSHS " nao e um numero primo"
WRITES
WRITELN
IF3END:
STOP


